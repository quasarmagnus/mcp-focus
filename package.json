{
  "name": "mcp-focus",
  "version": "0.1.0",
  "description": "MCP stdio proxy with hot-reload tool filtering and interactive TUI",
  "type": "module",
  "bin": {
    "mcp-focus": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.10",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@inquirer/checkbox": "^3.0.0",
    "@inquirer/select": "^5.1.5",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
